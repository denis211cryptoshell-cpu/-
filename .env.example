# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram ID администратора (число, узнать у @userinfobot)
ADMIN_ID=123456789

# Каналы для обязательной подписки (через запятую, ID или @username)
# Пример: @channel1,@channel2,-1001234567890
CHANNEL_IDS=@channel1,@channel2

# Путь к базе данных
DATABASE_PATH=data/bot.db

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
